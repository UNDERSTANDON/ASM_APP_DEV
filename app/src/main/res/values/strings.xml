    <string name="equation_text">2x² - 5x + 3 = 0</string>
    <string name="ai_answering">Glacier AI đang trả lời…</string>
    <string name="intro_method">Để giải phương trình bậc 2 có dạng ax² + bx + c = 0, chúng ta sẽ sử dụng công thức nghiệm (Delta). Dưới đây là các bước giải chi tiết:</string>
    <string name="step_1_title">Xác định các hệ số a, b, c</string>
    <string name="step_1_desc">Từ phương trình đã cho: 2x² - 5x + 3 = 0, ta có:</string>
    <string name="math_1">a = 2\nb = -5\nc = 3</string>
    <string name="math_2">Δ = (-5)² - 4 × 2 × 3\nΔ = 25 - 24\nΔ = 1</string>
    <string name="math_x1">x₁ = (5 + √1) / (2 × 2)\nx₁ = (5 + 1) / 4\nx₁ = 6 / 4 = 1.5</string>
    <string name="math_x2">x₂ = (5 - √1) / (2 × 2)\nx₂ = (5 - 1) / 4\nx₂ = 4 / 4 = 1</string>
    <string name="step_2_title">Tính biệt thức Delta (Δ)</string>
    <string name="step_2_desc">Công thức tính Delta: Δ = b² - 4ac</string>
    <string name="delta_info">Vì Δ > 0 nên phương trình có 2 nghiệm phân biệt.</string>
    <string name="step_3_title">Tính các nghiệm x₁, x₂</string>
    <string name="step_3_desc">Sử dụng công thức nghiệm: x = (-b ± √Δ) / 2a</string>
    <string name="root_1_label">Nghiệm thứ nhất (x₁):</string>
    <string name="root_2_label">Nghiệm thứ hai (x₂):</string>
