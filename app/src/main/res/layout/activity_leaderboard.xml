<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/lb_title"
        android:textColor="@color/on_surface"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Top 3 Podium area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:baselineAligned="false"
        android:layout_marginBottom="32dp">

        <!-- Rank 2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rank_2_name"
                android:textColor="@color/on_surface"
                android:textStyle="bold" />
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@color/lb_silver" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rank_2_label"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>

        <!-- Rank 1 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rank_1_name"
                android:textColor="@color/primary"
                android:textStyle="bold" />
            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@color/lb_gold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rank_1_label"
                android:textColor="@color/primary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Rank 3 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rank_3_name"
                android:textColor="@color/on_surface"
                android:textStyle="bold" />
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@color/lb_bronze" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rank_3_label"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>
    </LinearLayout>

    <!-- Simple List Items -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_panel"
        android:padding="16dp"
        android:text="@string/rank_4_placeholder"
        android:textColor="@color/on_surface"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_panel"
        android:padding="16dp"
        android:text="@string/rank_5_placeholder"
        android:textColor="@color/on_surface"
        android:layout_marginBottom="8dp" />

    <!-- Current User (Highlighted) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:padding="16dp"
        android:text="@string/current_user_rank_placeholder"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginTop="24dp" />

</LinearLayout>
