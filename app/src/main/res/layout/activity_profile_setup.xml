<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ProfileSetupActivity">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:drawableStartCompat="@drawable/ic_snowflake"
            android:drawablePadding="8dp"
            app:drawableTint="@color/primary"
            android:text="@string/glacier_edu"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/skip_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="@string/skip"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_setup_title"
                android:textColor="@color/on_surface"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/profile_setup_subtitle"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

            <!-- Stepper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/step1_circle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_step_circle_active">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/step_1"
                            android:textColor="@color/black"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/step1_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/step_level"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginBottom="20dp"
                    android:layout_weight="1"
                    android:background="@color/surface_container_highest" />

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/step2_circle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_step_circle">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/step_2"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="14sp" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/step2_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/step_subjects"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginBottom="20dp"
                    android:layout_weight="1"
                    android:background="@color/surface_container_highest" />

                <!-- Step 3 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:id="@+id/step3_circle"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_step_circle">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/step_3"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="14sp" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/step3_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/step_style"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Step Content Container -->
            <FrameLayout
                android:id="@+id/step_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <!-- Step 1: Level -->
                <LinearLayout
                    android:id="@+id/step1_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_level"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/level_thcs"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_input"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:text="@string/level_thcs"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/level_thpt"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_input"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:text="@string/level_thpt"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/level_uni"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_input"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:text="@string/level_uni"
                            android:textColor="@color/on_surface" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Step 2: Subjects -->
                <LinearLayout
                    android:id="@+id/step2_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/favorite_subjects"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/favorite_subjects_desc"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/subject_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        app:chipSpacingVertical="12dp">

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/subj_math_short" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/subj_phys_short" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/subj_chem_short" />

                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>

                <!-- Step 3: Style -->
                <LinearLayout
                    android:id="@+id/step3_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/explanation_style"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/style_concise_btn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_input"
                            android:padding="16dp"
                            android:text="@string/style_concise"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/style_detailed_btn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_input"
                            android:padding="16dp"
                            android:text="@string/style_detailed"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/style_step_btn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:padding="16dp"
                            android:text="@string/style_step"
                            android:textColor="@color/on_surface" />

                    </LinearLayout>
                </LinearLayout>

            </FrameLayout>

            <Button
                android:id="@+id/continue_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="48dp"
                android:backgroundTint="@color/primary"
                android:text="@string/continue_text"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <Button
                android:id="@+id/finish_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="48dp"
                android:backgroundTint="@color/primary"
                android:text="@string/finish"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>