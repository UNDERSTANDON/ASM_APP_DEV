<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_glass_panel_elevated"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/session_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle"
        android:backgroundTint="#1A7DD3FC"
        android:padding="8dp"
        android:src="@drawable/ic_smart_toy"
        android:contentDescription="Chatbot Session"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/primary" />

    <TextView
        android:id="@+id/session_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="Tiêu đề đoạn chat"
        android:textColor="@color/on_surface"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/delete_session_btn"
        app:layout_constraintStart_toEndOf="@id/session_icon"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/session_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:text="0 tin nhắn"
        android:textColor="@color/on_surface_variant"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@id/delete_session_btn"
        app:layout_constraintStart_toEndOf="@id/session_icon"
        app:layout_constraintTop_toBottomOf="@id/session_title" />

    <ImageView
        android:id="@+id/delete_session_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_trash_2"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Xóa đoạn chat"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFF5959" />

</androidx.constraintlayout.widget.ConstraintLayout>
