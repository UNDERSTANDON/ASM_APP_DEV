<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <!-- AI Avatar -->
    <View
        android:id="@+id/ai_avatar_bg"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_circle"
        android:backgroundTint="@color/surface_container_high"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ai_avatar_icon"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="AI"
        android:src="@drawable/ic_snowflake"
        app:layout_constraintBottom_toBottomOf="@id/ai_avatar_bg"
        app:layout_constraintEnd_toEndOf="@id/ai_avatar_bg"
        app:layout_constraintStart_toStartOf="@id/ai_avatar_bg"
        app:layout_constraintTop_toTopOf="@id/ai_avatar_bg"
        app:tint="@color/primary" />

    <!-- AI Name Header -->
    <TextView
        android:id="@+id/text_ai_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="AI Mentor"
        android:textColor="@color/primary"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/ai_avatar_bg"
        app:layout_constraintTop_toTopOf="@id/ai_avatar_bg" />

    <!-- AI Chat Bubble Container -->
    <LinearLayout
        android:id="@+id/ai_chat_bubble"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/bg_chat_bubble_ai"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ai_avatar_bg"
        app:layout_constraintTop_toBottomOf="@id/text_ai_name">

        <!-- Thinking / Loading State Indicator -->
        <ProgressBar
            android:id="@+id/thinking_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/primary" />

        <TextView
            android:id="@+id/text_thinking_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:text="AI đang suy nghĩ..."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Main Simplified Explanation (Standard text output) -->
        <TextView
            android:id="@+id/text_ai_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI response placeholder"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <!-- Expandable Details Section -->
        <LinearLayout
            android:id="@+id/layout_ai_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Divider -->
            <View
                android:id="@+id/divider_details"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp"
                android:background="@color/outline_variant" />

            <!-- Toggle Steps Button -->
            <LinearLayout
                android:id="@+id/btn_toggle_steps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Xem các bước giải chi tiết"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/icon_toggle_steps"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_expand_more"
                    app:tint="@color/primary" />
            </LinearLayout>

            <!-- Steps Content -->
            <LinearLayout
                android:id="@+id/layout_steps_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_math_block"
                android:orientation="vertical"
                android:padding="10dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/text_steps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Steps placeholder"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Formulas Section -->
            <LinearLayout
                android:id="@+id/layout_formulas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Công thức sử dụng:"
                    android:textColor="@color/secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_formulas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Alternatives Section -->
            <LinearLayout
                android:id="@+id/layout_alternatives"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cách giải thay thế:"
                    android:textColor="@color/tertiary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_alternatives"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Common Mistakes Section -->
            <LinearLayout
                android:id="@+id/layout_mistakes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lỗi thường gặp cần tránh:"
                    android:textColor="@color/error"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_mistakes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- AI Time -->
    <TextView
        android:id="@+id/text_ai_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="12:00"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@id/ai_chat_bubble"
        app:layout_constraintTop_toBottomOf="@id/ai_chat_bubble" />

</androidx.constraintlayout.widget.ConstraintLayout>
